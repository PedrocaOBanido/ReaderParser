<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Samsung Search public API permissions -->
    <uses-permission android:name="com.samsung.android.smartsuggestions.search.permission.WRITE" />
    <uses-permission android:name="com.samsung.android.smartsuggestions.search.permission.READ" />
    <uses-permission android:name="com.samsung.android.smartsuggestions.search.permission.UPDATE_INDEX" />

    <application
        android:name=".App"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ReaderParser">

        <!-- tools:ignore="Instantiatable": MainActivity is annotated with @AndroidEntryPoint.
             Hilt generates a subclass at compile time that lint cannot resolve, producing
             a false-positive Instantiatable warning. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            tools:ignore="Instantiatable">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep link for Samsung Search results: readerparser://series/{sourceId}/{seriesUrl} -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="readerparser"
                    android:host="series" />
            </intent-filter>
        </activity>

        <!--
            Remove the default WorkManager startup initializer so that our custom
            App.workManagerConfiguration (backed by HiltWorkerFactory) takes effect.
            Without this, WorkManager initialises itself before Hilt is ready and
            workers cannot receive injected dependencies.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!-- Samsung Search ACTION_UPDATE_INDEX receiver -->
        <receiver
            android:name=".workers.SamsungSearchUpdateReceiver"
            android:exported="true"
            android:permission="com.samsung.android.smartsuggestions.search.permission.SEND_ACTION_UPDATE_INDEX">
            <intent-filter>
                <action android:name="com.samsung.android.smartsuggestions.search.ACTION_UPDATE_INDEX" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
