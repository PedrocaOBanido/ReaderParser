{
  "$schema": "https://opencode.ai/config.json",

  "permission": {
    "edit": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "task": {
      "*": "allow",
      "domain-author": "allow",
      "journey-runner": "allow",
      "room-migration": "allow",
      "reviewer": "allow",
      "runner": "allow",
      "screen-author": "allow",
      "source-author": "allow",
      "integrator": "allow"
    },
    "bash": {

      "*":                                  "ask",

      "ls *":                               "allow",
      "cat *":                              "allow",
      "find *":                             "allow",
      "grep *":                             "allow",
      "rg *":                               "allow",
      "head *":                             "allow",
      "tail *":                             "allow",
      "wc *":                               "allow",
      "tree *":                             "allow",
      "file *":                             "allow",
      "echo *":                             "allow",

      "git status *":                       "allow",
      "git log *":                          "allow",
      "git diff *":                         "allow",
      "git show *":                         "allow",
      "git branch":                         "allow",
      "git branch --show-current *":        "allow",
      "git add *":                          "ask",
      "git restore *":                      "allow",
      "git stash":                          "allow",
      "git stash list":                     "allow",
      "git stash show *":                   "allow",
      "git commit *":                       "ask",

      "git push *":                         "ask",
      "git pull *":                         "ask",
      "git merge *":                        "ask",
      "git rebase *":                       "ask",
      "git checkout *":                     "ask",
      "git switch *":                       "ask",
      "git tag *":                          "ask",

      "git reset --hard *":                 "deny",
      "git clean -fd*":                     "deny",
      "git push --force*":                  "deny",
      "git push -f *":                      "deny",

      "openspec *":                         "allow",
      "rtk *":                              "allow",

      "./gradlew *":                        "allow",

      "./gradlew :app:ktlintFormat":        "ask",
      "./gradlew :app:installDebug":        "ask",
      "./gradlew :app:assembleRelease":     "ask",
      "./gradlew :app:bundleRelease":       "ask",
      "./gradlew :app:connectedDebugAndroidTest": "ask",
      "./gradlew clean":                    "ask",
      
      "android *":                          "allow",
      "adb devices":                        "allow",
      "adb logcat *":                       "allow",
      "adb shell am *":                     "ask",
      "adb *":                              "ask",

      "rm -rf *":                           "deny",
      "rm -fr *":                           "deny",
      "chmod -R *":                         "deny",
      "chown *":                            "deny",
      "sudo *":                             "ask"

    }
  },

  "agent": {
    "build": {
      "permission": {
        "bash": {
          "git *":                              "deny",
          "gh *":                               "deny",
          "./gradlew :app:assembleDebug":       "deny",
          "./gradlew :app:assembleDebug *":     "deny",
          "./gradlew * :app:assembleDebug":     "deny",
          "./gradlew * :app:assembleDebug *":   "deny",
          "./gradlew :app:lintDebug":           "deny",
          "./gradlew :app:lintDebug *":         "deny",
          "./gradlew * :app:lintDebug":         "deny",
          "./gradlew * :app:lintDebug *":       "deny",
          "./gradlew :app:testDebugUnitTest":   "deny",
          "./gradlew :app:testDebugUnitTest *": "deny",
          "./gradlew * :app:testDebugUnitTest": "deny",
          "./gradlew * :app:testDebugUnitTest *": "deny"
        }
      }
    },
    "runner": {
      "permission": {
        "bash": {
          "./gradlew :app:assembleDebug": "allow",
          "./gradlew :app:lintDebug":     "allow",
          "./gradlew :app:testDebugUnitTest": "allow",
          "./gradlew :app:ktlintCheck":   "allow",
          "./gradlew :app:ktlintFormat":  "allow",
          "./gradlew :app:detekt":        "allow",
          "git status *":                 "allow",
          "git diff *":                   "allow",
          "git log *":                    "allow",
          "git show *":                   "allow"
        }
      }
    },
    "reviewer": {
      "permission": {
        "bash": {
          "git status *":                 "allow",
          "git diff *":                   "allow",
          "git log *":                    "allow",
          "git show *":                   "allow",
          "./gradlew *":                  "deny"
        }
      }
    },
    "integrator": {
      "permission": {
        "bash": {
          "git add *":                    "allow",
          "git commit *":                 "allow",
          "git push *":                   "allow",
          "git push --force*":            "deny",
          "git push * --force*":          "deny",
          "git push -f":                  "deny",
          "git push -f *":                "deny",
          "git push * -f *":              "deny",
          "git branch *":                 "allow",
          "git checkout *":               "allow",
          "git switch *":                 "allow",
          "git reset --hard":             "deny",
          "git reset --hard *":           "deny",
          "git clean":                     "deny",
          "git clean *":                   "deny",
          "git clean -fd":                 "deny",
          "git clean -fd*":                "deny",
          "gh pr create *":               "allow",
          "gh pr merge *":                "allow",
          "gh pr checks *":               "allow",
          "gh run view *":                "allow"
        }
      }
    }
  },

  "lsp": {
    "kotlin": {
      "command": ["kotlin-lsp"],
      "extensions": [".kt", "kts"]
    }
  },

  "watcher": {
    "ignore": [
      "build/**",
      "**/build/**",
      ".gradle/**",
      ".idea/**",
      ".opencode/node_modules/**",
      ".opencode/package-lock.json",
      ".opencode/package.json",
      ".opencode/project-structure.md",
      ".kotlin/**",
      ".cxx/**",
      ".externalNativeBuild/**",
      "captures/**",
      "**/*.iml",
      "local.properties",
      "**/generated/**",
      "**/intermediates/**",
      "**/outputs/**",
      "**/tmp/**"
    ]
  }
}
