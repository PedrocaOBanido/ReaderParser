{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(tree:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(which:*)",
      "Bash(pwd)",
      "Bash(echo:*)",
      "Bash(mkdir:*)",
      "Bash(mkdir -p:*)",
      "Bash(w3m:*)",

      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(git ls-files:*)",
      "Bash(git rev-parse:*)",
      "Bash(git config --get:*)",
      "Bash(git add:*)",
      "Bash(git restore:*)",
      "Bash(git stash)",
      "Bash(git stash:*)",
      "Bash(git mv:*)",

      "Bash(./gradlew :app:assembleDebug)",
      "Bash(./gradlew :app:lintDebug)",
      "Bash(./gradlew :app:testDebugUnitTest)",
      "Bash(./gradlew :app:testDebug:*)",
      "Bash(./gradlew :app:ktlintCheck)",
      "Bash(./gradlew :app:detekt)",
      "Bash(./gradlew :app:dependencies:*)",
      "Bash(./gradlew :app:tasks)",
      "Bash(./gradlew help:*)",
      "Bash(./gradlew tasks)",
      "Bash(./gradlew --version)",

      "Bash(android:*)",
      "Bash(adb devices)",
      "Bash(adb devices:*)",
      "Bash(adb wait-for-device:*)",
      "Bash(adb logcat:*)",
      "Bash(adb pull:*)",
      "Bash(adb shell getprop:*)",
      "Bash(adb shell pm list:*)",
      "Bash(adb shell input:*)",
      "Bash(adb shell dumpsys:*)",
      "Bash(adb shell ls:*)",
      "Bash(adb shell am force-stop:*)",
      "Bash(adb shell am start:*)",
      "Bash(adb emu kill)",

      "Bash(scripts/ci-check)",
      "Bash(scripts/ci-check:*)",
      "Bash(scripts/pre-push)",
      "Bash(scripts/pre-push:*)",
      "Bash(scripts/emulator)",
      "Bash(scripts/emulator:*)",
      "Bash(scripts/run-journeys)",
      "Bash(scripts/run-journeys:*)",
      "Bash(bash scripts/ci-check:*)",
      "Bash(bash scripts/pre-push:*)",
      "Bash(bash scripts/emulator:*)",
      "Bash(bash scripts/run-journeys:*)",

      "Bash(sed -i:*)",
      "Bash(command -v:*)"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git tag:*)",
      "Bash(git cherry-pick:*)",

      "Bash(./gradlew :app:ktlintFormat)",
      "Bash(./gradlew :app:installDebug)",
      "Bash(./gradlew :app:assembleRelease)",
      "Bash(./gradlew :app:bundleRelease)",
      "Bash(./gradlew :app:connectedDebugAndroidTest)",
      "Bash(./gradlew clean)",

      "Bash(adb shell am:*)",
      "Bash(python3:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(sudo:*)",
      "Bash(chmod -R:*)",
      "Bash(chown:*)",
      "Bash(curl * | *sh*)",
      "Bash(wget * | *sh*)",
      "Bash(adb install:*)",
      "Bash(adb uninstall:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)"
    ]
  }
}
