#!/usr/bin/env bash
set -euo pipefail

# Full local CI check — run manually before opening a PR.
# Runs lint, unit tests, instrumented tests (if emulator/device present),
# and debug assemble.

echo "=============================="
echo " Lint"
echo "=============================="
./gradlew :app:lintDebug

echo ""
echo "=============================="
echo " Unit Tests"
echo "=============================="
./gradlew :app:testDebugUnitTest

echo ""
echo "=============================="
echo " Instrumented Tests"
echo "=============================="
HAS_DEVICE=false
if command -v adb >/dev/null 2>&1; then
    if adb devices 2>/dev/null | tail -n +2 | grep -q "device$"; then
        HAS_DEVICE=true
    fi
fi

if $HAS_DEVICE; then
    ./gradlew :app:connectedDebugAndroidTest
else
    echo "No emulator/device detected. Skipping instrumented tests."
fi

echo ""
echo "=============================="
echo " Assemble Debug"
echo "=============================="
./gradlew :app:assembleDebug

echo ""
echo "=============================="
echo " Journey Tests (optional)"
echo "=============================="
if command -v android >/dev/null 2>&1; then
    if scripts/emulator list 2>/dev/null | grep -q .; then
        HAS_AVD=true
    else
        HAS_AVD=false
    fi
else
    HAS_AVD=false
fi

if $HAS_AVD; then
    scripts/emulator start
    adb wait-for-device shell 'while [[ -z $(getprop sys.boot_completed) ]]; do sleep 1; done'
    android run --apks=app/build/outputs/apk/debug/app-debug.apk
    echo "Emulator ready. Journey tests listed below."
    echo "To execute: have an agent load skill('android-cli') and follow the steps."
    scripts/run-journeys
    scripts/emulator stop
else
    echo "No AVD configured. Run 'scripts/emulator create' first."
fi

echo ""
echo "=============================="
echo " ci-check: PASSED"
echo "=============================="
